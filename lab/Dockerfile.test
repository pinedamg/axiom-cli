# Axiom Sandbox Lab Pro: Extreme Validation (includes Homebrew)
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies for testing and Homebrew
RUN apt-get update && apt-get install -y \
    curl \
    git \
    zsh \
    bash \
    fish \
    sudo \
    build-essential \
    procps \
    file \
    && rm -rf /var/lib/apt/lists/*

# Create test user
RUN useradd -m -s /bin/zsh axiom-tester && \
    echo "axiom-tester ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER axiom-tester
WORKDIR /home/axiom-tester

# Install Homebrew (Linuxbrew)
RUN /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

# Setup environment for Homebrew
ENV PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:${PATH}"

# Initialize shell configs
RUN touch .zshrc .bashrc && mkdir -p .config/fish && touch .config/fish/config.fish

# Axiom Workspace setup
ENV AXIOM_HOME=/home/axiom-tester/.axiom
RUN mkdir -p $AXIOM_HOME

CMD ["/bin/zsh"]
